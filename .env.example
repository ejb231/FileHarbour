# SyncCore environment configuration
# Copy this file to .env and set your values.

# Local folder to watch or store uploaded files
SYNC_FOLDER=./data/sync_folder

# Central server the client uploads to
SERVER_URL=https://localhost:8443
PORT=8443

# Shared secret used by both the client and the server
API_KEY=change-me-to-a-real-secret

# TLS certificate files used by the HTTPS server
SSL_CERT=cert.pem
SSL_KEY=key.pem

# Optional node label used in logs and conflict names
NODE_ID=node-1

# Logging and safety controls
LOG_LEVEL=INFO
MAX_UPLOAD_MB=500
VERIFY_TLS=false
